# Google Sheets
SPREADSHEET_ID=1YbsObqu2pbSR3cSVPTRGvsZdvgCSxAluo5KAY8taNec
SHEET_NAME=Лист1

# One of these authentication methods is enough:
# 1) base64-encoded service account JSON, recommended for GitHub Actions
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# 2) local path to service account JSON, recommended for local runs
GOOGLE_APPLICATION_CREDENTIALS=service-account.json

# Optional Google Drive upload folder for the generated PDF
DRIVE_FOLDER_ID=

# Runtime behavior
FORCE_REFRESH=false
MAX_ROWS=0
INCLUDE_ONLY_CHECKED=false
ENABLE_PLAYWRIGHT_FALLBACK=false
REQUEST_DELAY_SECONDS=0.7
